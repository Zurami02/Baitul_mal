<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="549.0" prefWidth="706.0" style="-fx-border-color: Lime;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mbtec.baitulmal02.controller.RelatorioController">
   <children>
      <TableView fx:id="tableViewExtrato" layoutX="14.0" layoutY="43.0" prefHeight="460.0" prefWidth="678.0" style="-fx-border-color: Lime;">
        <columns>
          <TableColumn fx:id="colunaCodigoTipo" prefWidth="58.0" text="Ordem" />
          <TableColumn fx:id="colunaDescricaoExtrato" prefWidth="225.0" text="Descricao" />
            <TableColumn fx:id="colunaMovimentoTipo" prefWidth="126.0" text="Movimento" />
            <TableColumn fx:id="colunaData" prefWidth="124.0" text="Data" />
            <TableColumn fx:id="colunaMontante" prefWidth="69.0" text="Montante" />
            <TableColumn fx:id="colunaSaldoDisponivel" prefWidth="73.0" text="Dispoonivel" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
      <Label layoutX="14.0" layoutY="509.0" prefHeight="30.0" prefWidth="200.0" text="ISLAM PARA TODOS" textFill="#03eb22">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <Button layoutX="506.0" layoutY="509.0" mnemonicParsing="false" onAction="#btnImprimir" text="Imprimir">
         <graphic>
            <ImageView fitHeight="22.0" fitWidth="34.0" onMouseClicked="#btnImprimirImagem" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@icones/impressão-50.png" />
               </image>
            </ImageView>
         </graphic>
      </Button>
      <Label layoutX="14.0" layoutY="8.0" prefHeight="30.0" prefWidth="517.0" text="Extrado de Movimentos em datas selecionadas" textFill="#03eb22">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <Button layoutX="604.0" layoutY="509.0" mnemonicParsing="false" onAction="#btnCancelar" text="Cancelar">
         <graphic>
            <ImageView fitHeight="22.0" fitWidth="34.0" onMouseClicked="#btnCancelar" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@icones/icons8-cancelar-50.png" />
               </image>
            </ImageView>
         </graphic>
      </Button>
   </children>
</AnchorPane>
